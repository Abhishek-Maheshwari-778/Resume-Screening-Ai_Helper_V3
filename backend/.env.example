# MongoDB Configuration
# MONGODB_URL=mongodb+srv://<username>:<password>@cluster.mongodb.net/resume_platform
MONGODB_URL=mongodb://localhost:27017/resume_platform

# Security
SECRET_KEY=generate-a-new-random-secret-key-here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# AI APIs (MANDATORY)
GROQ_API_KEY=gsk_your_groq_api_key_here
# DEEPSEEK_API_KEY=decommissioned_in_V3

# Firebase Configuration (Optional - for advanced auth/storage)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_WEB_API_KEY=your-api-key
FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=your-sender-id
FIREBASE_APP_ID=1:your-app-id:web:your-web-id
FIREBASE_MEASUREMENT_ID=your-measurement-id

# Application
APP_NAME=AI Resume Platform V3
ENVIRONMENT=development
DEBUG=true
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_DIR=temp_uploads
